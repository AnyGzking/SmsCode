    "sections": {
      "introduction": {
        "title": "写在前面",
        "lead": "在使用该项目接口之前，请确保您满足以下条件：",
        "items": [
          "具备网络请求的基础知识 😪",
          "具有开发者能力 😨",
          "熟知双 Token 刷新机制 😥",
          "具备调试、查询日志、排错问题的能力 😁"
        ],
        "summary": "本项目旨在提供一套通用的 API 接入方案，帮助您快速实现业务功能集成。",
        "summaryTitle": "本项目应当是一套通用 API",
        "summaryItems": [
          "没有固定请求地址，请求地址取决于你的账户地址。",
          "通常请求地址是在用的 IP / 域名。",
          "请严格按照文档要求进行开发。",
          "如需技术支持请描述问题、BUG 复现流程，以及请求报文和响应报文。"
        ],
        "note": "文档写得比较随意，轻点骂 💔"
      },
      "authentication": {
        "title": "对接前提与认证",
        "lead": "在对接之前，你应该在控制台后台拿到你的 APPID 和 apiKey 令牌：",
        "items": [
          "appid：目前使用的商户 / 用户 ID。",
          "apikey：系统特有加密生成的密钥，用于接口签名或直接认证。",
          "IP 白名单：必须配置为你的服务器请求出网 IP，不配置会被防火墙直接拦截。",
          "配置多个 IP 时请使用英文逗号分开。"
        ]
      },
      "apiStandards": {
        "title": "通用 API 规范",
        "items": [
          "请求地址：没有固定请求地址，请求地址取决于你的账户分配地址（通常是当前正在使用的 IP / 域名）。",
          "请求方法：全局使用 POST 请求，不接受 GET 方法（除非文档中特殊说明）。",
          "请求类型：请求头 Content-Type 必须严格指定为 application/json。",
          "命名规范：大部分数据返回字段都是驼峰式命名，如果不是，会在具体接口文档中特别注明。"
        ],
        "baseUrlLabel": "当前环境请求地址"
      },
      "responseFormat": {
        "title": "通用响应格式",
        "lead": "所有的接口返回的均为标准 JSON 格式数据。根据 code 状态码判断业务处理是否成功。",
        "successTitle": "成功响应",
        "errorTitle": "错误响应",
        "note": "注：code 为非 200/0 时，通常代表业务或系统发生异常，请参考 msg 字段进行排查。"
      },
      "apiList": {
        "title": "API 接口列表",
        "lead": "以下是当前开放的核心接口，建议按调用顺序进行接入。",
        "summaryTitle": "摘要",
        "authTitle": "鉴权",
        "contentTypeTitle": "请求类型",
        "paramsTitle": "请求参数",
        "responseTitle": "响应示例",
        "table": {
          "name": "参数名",
          "type": "类型",
          "required": "必填",
          "description": "说明",
          "example": "示例"
        },
        "requiredYes": "是",
        "requiredNo": "否",
        "items": [
          {
            "id": "api-token",
            "title": "获取 Token",
            "path": "/api/auth/getToken",
            "method": "POST",
            "summary": "在 Api 内任何操作，你必须通过此接口获取到 token 和 refreshToken。此接口支持 POST/GET 传参数，支持 form-data/json 传入，建议统一使用 json。",
            "auth": "否",
            "requestType": "application/json / multipart/form-data",
            "params": [
              {
                "name": "appId",
                "type": "string",
                "required": true,
                "desc": "当前使用的户 ID",
                "example": "251"
              },
              {
                "name": "appKey",
                "type": "string",
                "required": true,
                "desc": "平台生成的 apiKey",
                "example": "d41d8cd98f00b204e9800998ecf8427e"
              }
            ],
            "successExample": "{\n  \"code\": 200,\n  \"msg\": \"获取Token成功\",\n  \"data\": {\n    \"token\": \"eyJ...\",\n    \"refreshToken\": \"eyJ...\",\n    \"expiresIn\": 7200\n  },\n  \"time\": 1768428991\n}"
          },
          {
            "id": "api-refresh-token",
            "title": "刷新 Token",
            "path": "/api/auth/refreshToken",
            "method": "POST",
            "summary": "此接口支持 GET/POST 请求，请求参数 refreshToken，支持 form-data/json，刷新成功后会拿到新的 token 和新的 refreshToken。",
            "auth": "否",
            "requestType": "application/json / multipart/form-data",
            "params": [
              {
                "name": "refreshToken",
                "type": "string",
                "required": true,
                "desc": "登录后保存的刷新令牌",
                "example": "eyJ0eXAiOiJKV1QiLCJ..."
              }
            ],
            "successExample": "{\n  \"code\": 200,\n  \"msg\": \"操作成功\",\n  \"data\": {\n    \"token\": \"eyJ...\",\n    \"refreshToken\": \"eyJ...\",\n    \"expiresIn\": 7189\n  },\n  \"time\": 1768429572\n}"
          },
          {
            "id": "api-user-info",
            "title": "获取账户信息",
            "path": "/api/auth/getUserInfo",
            "method": "POST",
            "summary": "获取用户的账户信息，如果需要的话，请求头传递 Authorization，token 可携带 Bearer {Token值} 均支持。",
            "auth": "是",
            "requestType": "application/json",
            "params": [
              {
                "name": "Authorization",
                "type": "header",
                "required": false,
                "desc": "用户登录后获取的 token，支持 Bearer 前缀",
                "example": "Bearer eyJ0eXAiOiJKV1QiLCJ..."
              }
            ],
            "successExample": "{\n  \"code\": 200,\n  \"msg\": \"获取用户信息成功\",\n  \"data\": {\n    \"userName\": \"1008611\",\n    \"gender\": 0,\n    \"phone\": null,\n    \"email\": null,\n    \"avatar\": \"https://hk10000.cn/make/assets/images/avatar.jpg\",\n    \"balance\": 197,\n    \"lastLoginTime\": \"2026-01-15 06:55:09\",\n    \"lastLoginIp\": \"172.17.0.1\",\n    \"lastLoginDevice\": \"Chrome 143.0.0 / Windows 10.0.0\"\n  },\n  \"time\": 1768431333\n}"
          },
          {
            "id": "api-country-code",
            "title": "国家地区库",
            "path": "/api/business/getCountryCode",
            "method": "POST",
            "summary": "获取系统内的地址信息库。国家库基本没有什么变化，建议存储到本地。",
            "auth": "可选",
            "requestType": "application/json / multipart/form-data",
            "params": [
              {
                "name": "Authorization",
                "type": "header",
                "required": false,
                "desc": "可选 token 请求头",
                "example": "eyJ0eXAiOiJKV1QiLCJ..."
              }
            ],
            "successExample": "{\n  \"code\": 200,\n  \"msg\": \"获取国家列表成功\",\n  \"data\": [\n    {\n      \"id\": 144,\n      \"name\": \"乌兹别克斯坦\",\n      \"code\": \"uzb\",\n      \"flag\": \"flag:uz-4x3\",\n      \"phoneCode\": \"+998\"\n    }\n  ],\n  \"time\": 1768529083\n}"
          },
          {
            "id": "api-project",
            "title": "获取在用项目",
            "path": "/api/business/getProject",
            "method": "POST",
            "summary": "获取线上可用项目。",
            "auth": "可选",
            "requestType": "application/json",
            "params": [
              {
                "name": "Authorization",
                "type": "header",
                "required": false,
                "desc": "可选 token 请求头",
                "example": "eyJ0eXAiOiJKV1QiLCJ..."
              }
            ],
            "successExample": "{\n  \"code\": 200,\n  \"msg\": \"获取项目列表成功\",\n  \"data\": [\n    {\n      \"id\": \"25\",\n      \"name\": \"wsegvwsg\",\n      \"code\": \"phl-1064-88q75\",\n      \"price\": \"1.00\",\n      \"country\": 34\n    }\n  ],\n  \"time\": 1768432316\n}"
          },
          {
            "id": "api-get-phone",
            "title": "获取手机号码",
            "path": "/api/business/getPhone",
            "method": "POST",
            "summary": "获取手机号码，支持 form-data/json。获取号码后状态会变成等待验证码，此时需要调用获取验证码接口。新增返回 orderNo，获取验证码时需要传递。",
            "auth": "可选",
            "requestType": "application/json / application/x-www-form-urlencoded",
            "params": [
              {
                "name": "countryId",
                "type": "string",
                "required": true,
                "desc": "国家 ID，对应项目中的 country 字段",
                "example": "38"
              },
              {
                "name": "projectId",
                "type": "string",
                "required": true,
                "desc": "项目 ID",
                "example": "23"
              },
              {
                "name": "mobile",
                "type": "string",
                "required": false,
                "desc": "想继续使用上一个号码时可传",
                "example": ""
              },
              {
                "name": "type",
                "type": "string[]",
                "required": false,
                "desc": "号码类型，可选 sms / voice / incall，也可传 all 或空",
                "example": "[\"sms\"]"
              },
              {
                "name": "callbackUrl",
                "type": "string",
                "required": false,
                "desc": "短信回调地址",
                "example": "https://example.com/callback"
              }
            ],
            "successExample": "{\n  \"code\": 200,\n  \"msg\": \"获取号码成功，余额已冻结\",\n  \"data\": {\n    \"pkey\": \"E1E756...\",\n    \"getTime\": \"2026-01-19T03:01:22\",\n    \"country\": \"jpn\",\n    \"countryTel\": \"81\",\n    \"place\": \"89811000...\",\n    \"port\": \"COM104\",\n    \"phone\": \"8027973879\",\n    \"dock\": \"jpn-1260-103r1\",\n    \"orderNo\": \"20260119030118584911\"\n  },\n  \"time\": 1768762878\n}"
          },
          {
            "id": "api-get-code",
            "title": "获取验证码",
            "path": "/api/business/getPhoneCode",
            "method": "POST",
            "summary": "支持 form-data/json。此接口需要定时轮询以获取验证码，返回 code=200 后，后续不再重复返回验证码。",
            "auth": "可选",
            "requestType": "application/json / multipart/form-data",
            "params": [
              {
                "name": "orderNo",
                "type": "string",
                "required": true,
                "desc": "获取号码接口返回的唯一订单号",
                "example": "20260119030118584911"
              },
              {
                "name": "phone",
                "type": "string",
                "required": true,
                "desc": "获取号码接口返回的手机号",
                "example": "7555114644"
              },
              {
                "name": "pkey",
                "type": "string",
                "required": true,
                "desc": "获取号码接口返回的pkey",
                "example": "E1E756BB89D15……"
              }
            ],
           "successExample": "{\n  \"code\": 200,\n  \"msg\": \"获取验证码成功，已完成扣费\",\n  \"data\": {\n    \"orderNo\": \"20260119024813601712\",\n    \"phone\": \"9057898482\",\n    \"pkey\": \"E1E756BB89D15B57DE9B537A8EF0F92D81575038CA07EE88\",\n    \"codeNum\": \"123456\",\n    \"smsContent\": \"短信内容\",\n    \"deductPrice\": \"0.50\"\n  },\n  \"time\": 1768762116\n}"
          },
          {
            "id": "api-release-phone",
            "title": "释放号码",
            "path": "/api/business/setRel",
            "method": "POST",
            "summary": "支持 form-data/json。接口方可主动调用释放接口，避免额外的付费。",
            "auth": "可选",
            "requestType": "application/json / multipart/form-data",
            "params": [
              {
                "name": "orderNo",
                "type": "string",
                "required": true,
                "desc": "需要释放的订单号",
                "example": "20260119030118584911"
              },
              {
                "name": "phone",
                "type": "string",
                "required": true,
                "desc": "需要释放的手机号",
                "example": "7555114644"
              },
              {
                "name": "pkey",
                "type": "string",
                "required": true,
                "desc": "需要释放的pkey",
                "example": "E1E756BB89D15……"
              }
            ],
            "successExample": "{\n  \"code\": 200,\n  \"msg\": \"释放成功\",\n  \"data\": [],\n  \"time\": 1768763200\n}"
          },
          {
            "id": "api-black-phone",
            "title": "加黑号码",
            "path": "/api/business/addBlack",
            "method": "POST",
            "summary": "支持 form-data/json。接口方可调用此号码加黑，后续不会再获取到该号码。",
            "auth": "可选",
            "requestType": "application/json / multipart/form-data",
            "params": [
              {
                "name": "orderNo",
                "type": "string",
                "required": true,
                "desc": "需要加黑的订单号",
                "example": "20260119030118584911"
              },
              {
                "name": "phone",
                "type": "string",
                "required": true,
                "desc": "需要加黑的手机号",
                "example": "7555114644"
              },
              {
                "name": "pkey",
                "type": "string",
                "required": true,
                "desc": "需要加黑的pkey",
                "example": "E1E756BB89D15……"
              }
            ],
            "successExample": "{\n  \"code\": 200,\n  \"msg\": \"加黑成功\",\n  \"data\": [],\n  \"time\": 1768763300\n}"
          },
          {
            "id": "api-callback",
            "title": "短信回调推送",
            "path": "callbackUrl",
            "method": "POST",
            "summary": "在获取号码时传入 callbackUrl，后续系统接收到运营商短信时，会主动推送到这个地址。",
            "auth": "由业务方提供 URL",
            "requestType": "application/json",
            "successExample": "{\n  \"orderNo\": \"20260119024813601712\",\n  \"phone\": \"9057898482\",\n  \"pkey\": \"E1E756BB89D15B57DE9B537A8EF0F92D81575038CA07EE88\",\n  \"codeNum\": \"123456\",\n  \"smsContent\": \"短信内容\",\n  \"deductPrice\": \"0.50\"\n}"
          }
        ]
